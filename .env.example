# HTTP listen address for the gateway
ADDR=:8080

# Comma-separated API keys for Bearer token authentication on /quotes.
# Required — the gateway will refuse to start if unset.
API_KEYS=

# PostgreSQL connection string.
# When unset the gateway runs without persistence (no quote caching).
DATABASE_URL=postgres://carrier:secret@localhost:5432/carrier_gateway?sslmode=disable

# Structured log level: debug, info, warn, error.
LOG_LEVEL=info

# How often expired quotes are purged from the database.
CLEANUP_INTERVAL=5m

# Max in-flight requests before the gateway returns 503.
MAX_CONCURRENT_QUOTES=100

# Delta Insurance HTTP carrier.
# Both vars must be set to activate the carrier; leave blank to disable.
DELTA_BASE_URL=
DELTA_API_KEY=
